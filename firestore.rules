rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidUserProfile(data) {
      return (!('userId' in data) || (data.userId is string && data.userId.size() <= 128)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256)) &&
             (!('userType' in data) || (data.userType in ['student', 'professional', 'job-seeker']));
    }

    function isValidAssessment(data) {
      return (!('userId' in data) || (data.userId is string && data.userId.size() <= 128)) &&
             (!('results' in data) || (data.results is list));
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['role', 'content', 'createdAt']) &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 5000 &&
             (data.createdAt is timestamp || data.createdAt is string);
    }

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['userId', 'email']) && 
                      isValidUserProfile(incoming()) && 
                      incoming().userId == userId;
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'userType', 'onboardingCompleted', 'interests', 'skills', 'updatedAt', 'assessmentAnswers'])
      ) && incoming().userId == userId;
      
      // User Assessments
      match /assessments/{assessmentId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && 
                        isValidAssessment(incoming()) && 
                        (!('userId' in incoming()) || incoming().userId == userId);
      }

      // User Roadmaps (Cached & Progress)
      match /roadmaps/{roadmapId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId) && 
                         (!('completedMilestones' in incoming()) || incoming().completedMilestones is list);
      }

      // Chat Sessions
      match /chats/{chatId} {
        allow list, get: if isOwner(userId);
        allow create, update: if isOwner(userId);

        match /messages/{messageId} {
          allow list, get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidChatMessage(incoming());
        }
      }
    }
  }
}
